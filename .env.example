# Variables de entorno requeridas para el Agente de Inventario OmniRetail
# Copiar este archivo a .env y completar con tus credenciales

# === LLM Provider Principal: GitHub Models API ===
# Este token ha sido generado en: https://github.com/settings/tokens
GITHUB_TOKEN=tu_github_token_aqui
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# === LLM Provider Fallback: Google Gemini (opcional) ===
# API key generada desde: https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu_google_api_key_aqui

# === Modelo LLM ===
# Modelos disponibles en GitHub Models: gpt-4o-mini, gpt-4o, etc.
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# === Base de datos ===
DATABASE_PATH=data/omniretail.db

# === ChromaDB (RAG) ===
CHROMA_PERSIST_DIR=data/chroma_store
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Configuración del Agente ===
AGENT_VERBOSE=true
MEMORY_WINDOW_SIZE=10
